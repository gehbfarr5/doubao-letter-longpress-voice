# Orchestra runtime artifacts (planner/verifier reports stay tracked,
# only the wrapper-generated ephemeral files are ignored)
orchestra/.lock
orchestra/.done
orchestra/.codex-last.md
orchestra/.codex-status
orchestra/.baseline
orchestra/.baseline-stash
orchestra/.rx.patch
orchestra/.auto-git
orchestra/*.tmp

# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio / IntelliJ
*.iml
.idea/
.DS_Store
captures/

# Keystore files
*.jks
*.keystore

# External native build folder
.externalNativeBuild
.cxx/
